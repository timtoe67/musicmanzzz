<style>
:root {
  --black:#07020c;--deep:#0a040f;--surface:#100714;--border:#331a66;
  --green:#bf80ff;--green2:#9933ff;--green3:#bf80ff80;
  --dim:#7a3dbf;--muted:#4d2a6b;--text:#e8ccff;--white:#f5eeff;
  --scan-h:64px;--win-h:256px;--pad:2;
  --glow:0 0 12px #bf80ff55,0 0 30px #bf80ff22;
  --glow-strong:0 0 8px #bf80ff,0 0 25px #bf80ff88,0 0 60px #bf80ff33;
  --accept:#00ff88;--accept2:#00cc6a;--accept-glow:0 0 8px #00ff88,0 0 25px #00ff8888,0 0 60px #00ff8833;
  --deny:#ff3366;--deny2:#cc1144;--deny-glow:0 0 8px #ff3366,0 0 25px #ff336688,0 0 60px #ff336633;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--black);color:var(--text);font-family:'Share Tech Mono',monospace;min-height:100vh;overflow-x:hidden;cursor:crosshair}
body::before{content:'';position:fixed;inset:0;z-index:0;background-image:linear-gradient(rgba(191,128,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(191,128,255,.04) 1px,transparent 1px);background-size:40px 40px;pointer-events:none}
body::after{content:'';position:fixed;inset:0;z-index:999;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.07) 2px,rgba(0,0,0,.07) 4px);pointer-events:none}
.corner{position:fixed;width:60px;height:60px;z-index:10;pointer-events:none}
.corner::before,.corner::after{content:'';position:absolute;background:var(--green);box-shadow:var(--glow)}
.corner::before{width:2px;height:30px}.corner::after{width:30px;height:2px}
.corner.tl{top:16px;left:16px}.corner.tl::before{top:0;left:0}.corner.tl::after{top:0;left:0}
.corner.tr{top:16px;right:16px}.corner.tr::before{top:0;right:0}.corner.tr::after{top:0;right:0}
.corner.bl{bottom:16px;left:16px}.corner.bl::before{bottom:0;left:0}.corner.bl::after{bottom:0;left:0}
.corner.br{bottom:16px;right:16px}.corner.br::before{bottom:0;right:0}.corner.br::after{bottom:0;right:0}
.page{position:relative;z-index:1;max-width:960px;margin:0 auto;padding:0 1.5rem 5rem}

/* HEADER */
header{padding:3rem 0 2rem}
.header-bar{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem}
.brand-label{font-size:.55rem;letter-spacing:.5em;color:var(--dim);text-transform:uppercase;margin-bottom:.4rem;display:flex;align-items:center;gap:.5rem}
.brand-label::before{content:'';display:inline-block;width:20px;height:1px;background:var(--green);box-shadow:var(--glow)}
.logo{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(1.6rem,4.5vw,3rem);line-height:.85;color:var(--green);text-shadow:var(--glow-strong);letter-spacing:-.02em;position:relative}
.logo-sub{font-size:.6rem;letter-spacing:.4em;color:var(--dim);text-transform:uppercase;margin-top:.5rem}
.header-status{text-align:right;font-size:.55rem;letter-spacing:.15em;color:var(--dim);line-height:2;padding-top:.5rem}
.status-live{display:inline-flex;align-items:center;gap:6px;font-size:.6rem;color:var(--green)}
.status-live::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.glitch{position:relative}
.glitch::before,.glitch::after{content:attr(data-text);position:absolute;top:0;left:0;width:100%;font-family:'Orbitron',sans-serif;font-weight:900;font-size:inherit;line-height:inherit;letter-spacing:inherit}
.glitch::before{color:#cc99ff;animation:glitch1 4s infinite linear;clip-path:polygon(0 20%,100% 20%,100% 40%,0 40%);opacity:0}
.glitch::after{color:#ff66cc;animation:glitch2 4s infinite linear;clip-path:polygon(0 60%,100% 60%,100% 80%,0 80%);opacity:0}
@keyframes glitch1{0%,89%,91%,100%{opacity:0;transform:translateX(0)}90%{opacity:.8;transform:translateX(-4px)}}
@keyframes glitch2{0%,92%,94%,100%{opacity:0;transform:translateX(0)}93%{opacity:.8;transform:translateX(4px)}}
.cyber-divider{display:flex;align-items:center;gap:1rem;margin:1.5rem 0}
.cyber-divider::before,.cyber-divider::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--border),var(--green),var(--border),transparent)}
.divider-diamond{width:8px;height:8px;background:var(--green);transform:rotate(45deg);box-shadow:var(--glow);flex-shrink:0}

/* MACHINE */
@keyframes bootUp{from{opacity:0;transform:translateY(20px);filter:blur(4px)}to{opacity:1;transform:translateY(0);filter:blur(0)}}
@keyframes flashBorder{0%,100%{box-shadow:0 0 40px rgba(191,128,255,.06)}50%{box-shadow:0 0 60px rgba(191,128,255,.3),0 0 120px rgba(191,128,255,.1)}}
.machine{border:1px solid var(--border);background:var(--surface);position:relative;overflow:hidden;box-shadow:0 0 40px rgba(191,128,255,.06);animation:bootUp .6s ease both .2s}
.machine::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);box-shadow:0 0 10px var(--green)}
.machine.spinning{animation:flashBorder .4s ease-in-out infinite}
.machine-header{padding:.75rem 1.5rem;background:var(--deep);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.mh-left{font-size:.55rem;letter-spacing:.3em;color:var(--dim);display:flex;align-items:center;gap:.75rem}
.mh-left span{color:var(--green)}
.mh-right{display:flex;gap:1rem;font-size:.5rem;color:var(--muted);letter-spacing:.2em}

/* SLOTS */
.slots-grid{display:grid;grid-template-columns:1fr 1fr 1fr;position:relative}

.slots-highlight{
position:absolute;left:0;right:0;
top:129px;
height:var(--scan-h);
pointer-events:none;z-index:10;
background:rgba(191,128,255,.08);
border-top:1px solid rgba(191,128,255,.7);
border-bottom:1px solid rgba(191,128,255,.7);
box-shadow:0 0 28px rgba(191,128,255,.18),inset 0 0 40px rgba(191,128,255,.07);
}
.slots-highlight::after{
content:'';position:absolute;left:0;right:0;height:2px;
background:linear-gradient(90deg,transparent,var(--green),transparent);
box-shadow:0 0 10px var(--green);opacity:.75;
animation:scanSweep 2s ease-in-out infinite;
}
@keyframes scanSweep{0%{top:0;opacity:.85}50%{top:calc(var(--scan-h) - 2px);opacity:.3}100%{top:0;opacity:.85}}
.slots-highlight::before{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(191,128,255,.1) 0%,transparent 5%),linear-gradient(to left,rgba(191,128,255,.1) 0%,transparent 5%)}

.slot-col{border-right:1px solid var(--border);position:relative;overflow:hidden}
.slot-col:last-child{border-right:none}
.slot-header{height:33px;padding:.5rem 1rem;background:var(--deep);border-bottom:1px solid var(--border);font-size:.5rem;letter-spacing:.4em;color:var(--green);text-transform:uppercase;text-align:center;text-shadow:0 0 8px var(--green);display:flex;align-items:center;justify-content:center;gap:.5rem}
.slot-header::before,.slot-header::after{content:'//';opacity:.4;font-size:.45rem}
.slot-window{height:var(--win-h);overflow:hidden;position:relative}
.slot-window::before,.slot-window::after{content:'';position:absolute;left:0;right:0;height:80px;z-index:5;pointer-events:none}
.slot-window::before{top:0;background:linear-gradient(to bottom,var(--surface) 5%,transparent)}
.slot-window::after{bottom:0;background:linear-gradient(to top,var(--surface) 5%,transparent)}
.slot-reel{display:flex;flex-direction:column;will-change:transform}
.slot-item{height:var(--scan-h);display:flex;align-items:center;justify-content:center;padding:0 .6rem;text-align:center;font-size:.62rem;line-height:1.25;color:var(--muted);flex-shrink:0;letter-spacing:.03em;transition:color .15s,text-shadow .15s}
.slot-item.active{color:var(--green);text-shadow:0 0 12px var(--green),0 0 24px var(--green3);font-weight:700}
.slot-item.year-item{font-family:'Orbitron',sans-serif;font-size:1.7rem;font-weight:700;letter-spacing:.05em}

/* RESULT */
.result-panel{padding:1.5rem;border-top:1px solid var(--border);display:grid;grid-template-columns:1fr auto;gap:1.5rem;align-items:center;min-height:110px;opacity:0;transform:translateY(6px);transition:opacity .5s,transform .5s;background:var(--deep);position:relative}
.result-panel::before{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--green),transparent);opacity:.3}
.result-panel.visible{opacity:1;transform:translateY(0)}
.result-track-label{font-size:.5rem;letter-spacing:.4em;color:var(--dim);text-transform:uppercase;margin-bottom:.4rem;display:flex;align-items:center;gap:.5rem}
.result-track-label::before{content:'▶';color:var(--green);text-shadow:0 0 6px var(--green);font-size:.55rem;animation:blink 1s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.result-song-title{font-family:'Orbitron',sans-serif;font-size:clamp(1.1rem,3.5vw,1.9rem);font-weight:700;line-height:1.1;color:var(--white);text-shadow:0 0 20px rgba(191,128,255,.3);margin-bottom:.5rem;letter-spacing:.02em}
.result-meta{font-size:.6rem;color:var(--dim);letter-spacing:.1em;line-height:1.8}
.result-meta .hi{color:var(--green);text-shadow:0 0 6px var(--green3)}

/* QR CODE CLICKABLE WRAPPER */
.qr-link{text-decoration:none;display:block;cursor:pointer;transition:transform 0.2s}
.qr-link:hover{transform:scale(1.03)}
.qr-wrap{display:flex;flex-direction:column;align-items:center;gap:.4rem;flex-shrink:0}
.qr-frame{padding:6px;background:var(--white);border:1px solid var(--green);box-shadow:0 0 15px rgba(191,128,255,.2);transition:box-shadow .2s}
.qr-link:hover .qr-frame{box-shadow:0 0 20px rgba(191,128,255,.6),0 0 40px rgba(191,128,255,.2)}
.qr-frame canvas,.qr-frame img{display:block}
.qr-label{font-size:.45rem;letter-spacing:.2em;color:var(--dim);text-transform:uppercase;text-align:center;transition:color .2s}
.qr-link:hover .qr-label{color:var(--green);text-shadow:0 0 6px var(--green)}

/* VERDICT BUTTONS */
.verdict-row{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:.8rem;align-items:center;background:var(--deep);opacity:0;pointer-events:none;transition:opacity .4s .3s}
.verdict-row.visible{opacity:1;pointer-events:all}
.verdict-btn{font-family:'Orbitron',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.18em;background:transparent;border:1px solid;padding:.65rem 1.5rem;cursor:crosshair;text-transform:uppercase;position:relative;overflow:hidden;transition:color .2s,box-shadow .2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);flex:1}
.verdict-btn::before{content:'';position:absolute;inset:0;transform:scaleX(0);transform-origin:left;transition:transform .2s;z-index:-1}
.verdict-btn:disabled{opacity:.35;cursor:not-allowed}
.verdict-btn:disabled::before{display:none}
.accept-btn{color:var(--accept);border-color:var(--accept);box-shadow:0 0 12px rgba(0,255,136,.12)}
.accept-btn::before{background:var(--accept)}
.accept-btn:hover:not(:disabled){color:#000;box-shadow:var(--accept-glow)}.accept-btn:hover:not(:disabled)::before{transform:scaleX(1)}
.deny-btn{color:var(--deny);border-color:var(--deny);box-shadow:0 0 12px rgba(255,51,102,.12)}
.deny-btn::before{background:var(--deny)}
.deny-btn:hover:not(:disabled){color:#fff;box-shadow:var(--deny-glow)}.deny-btn:hover:not(:disabled)::before{transform:scaleX(1)}
.vote-counts{display:flex;gap:1.2rem;font-size:.55rem;letter-spacing:.15em;color:var(--dim);flex-shrink:0}
.vote-accept{color:var(--accept);text-shadow:0 0 6px rgba(0,255,136,.4)}
.vote-deny{color:var(--deny);text-shadow:0 0 6px rgba(255,51,102,.4)}

/* CONTROLS */
.controls{padding:1.2rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:1rem;align-items:center;background:var(--deep)}
.spin-btn{font-family:'Orbitron',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.2em;background:transparent;color:var(--green);border:1px solid var(--green);padding:.75rem 2rem;cursor:crosshair;text-transform:uppercase;position:relative;overflow:hidden;transition:color .2s,box-shadow .2s;box-shadow:0 0 12px rgba(191,128,255,.15);clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);flex-shrink:0}
.spin-btn::before{content:'';position:absolute;inset:0;background:var(--green);transform:scaleX(0);transform-origin:left;transition:transform .2s;z-index:-1}
.spin-btn:hover{color:var(--black);box-shadow:var(--glow-strong)}.spin-btn:hover::before{transform:scaleX(1)}
