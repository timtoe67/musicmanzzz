.ctrl-info{font-size:.5rem;letter-spacing:.2em;color:var(--dim)}.ctrl-info span{color:var(--green)}

/* HISTORY */
.history-section{margin-top:1.5rem;border:1px solid var(--border);background:var(--surface);position:relative;overflow:hidden}
.history-section::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--green2),transparent);opacity:.4}
.history-head{padding:.65rem 1.2rem;border-bottom:1px solid var(--border);font-size:.5rem;letter-spacing:.4em;color:var(--dim);text-transform:uppercase;background:var(--deep);display:flex;justify-content:space-between}
