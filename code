.history-item{display:flex;align-items:center;gap:1rem;padding:.6rem 1.2rem;border-bottom:1px solid var(--border);font-size:.6rem;color:var(--muted);transition:background .15s}
.history-item:last-child{border-bottom:none}.history-item:first-child{color:var(--text);background:rgba(191,128,255,.03)}.history-item:hover{background:rgba(191,128,255,.04)}
.h-idx{font-family:'Orbitron',sans-serif;font-size:.65rem;color:var(--border);width:24px;flex-shrink:0}
.history-item:first-child .h-idx{color:var(--green);text-shadow:0 0 6px var(--green)}
.h-song{flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.h-info{flex-shrink:0;color:var(--dim);font-size:.55rem;letter-spacing:.1em}
.h-verdict{flex-shrink:0;font-size:.55rem;letter-spacing:.12em;font-family:'Orbitron',sans-serif;font-weight:700}
.h-verdict.accepted{color:var(--accept);text-shadow:0 0 6px rgba(0,255,136,.4)}
.h-verdict.denied{color:var(--deny);text-shadow:0 0 6px rgba(255,51,102,.4)}
.h-verdict.pending{color:var(--muted)}
footer{text-align:center;padding:2rem 0 0;font-size:.5rem;letter-spacing:.3em;color:var(--border)}
</style>

