const voteTally = {};
function tallyKey(track) { return track.artist + '||' + track.song; }
function getVotes(track) {
  const k = tallyKey(track);
  if (!voteTally[k]) voteTally[k] = { accept: 0, deny: 0 };
  return voteTally[k];
}

function buildReel(id, items, isYear) {
  const reel = document.getElementById(id);
  reel.innerHTML = '';
  const mk = txt => {
    const el = document.createElement('div');
    el.className = 'slot-item' + (isYear ? ' year-item' : '');
    el.textContent = txt;
    reel.appendChild(el);
  };
  for (let i = 0; i < PAD; i++) mk(items[(items.length - PAD + i) % items.length]);
  items.forEach(mk);
  for (let i = 0; i < PAD; i++) mk(items[i % items.length]);
}

function setPos(id, idx) {
  const reel = document.getElementById(id);
  const offset = idx * ITEM_H - (WIN_H / 2 - ITEM_H / 2) + PAD * ITEM_H;
  reel.style.transform = `translateY(${-offset}px)`;
  reel.querySelectorAll('.slot-item')[idx + PAD]?.classList.add('active');
}

function initReels() {
  const artists = [...new Set(catalog.map(t => t.artist))];
  const songs   = catalog.map(t => t.song);
  const years   = [...new Set(catalog.map(t => t.year))].sort();
  buildReel('reel-artist', artists, false);
  buildReel('reel-song',   songs,   false);
  buildReel('reel-year',   years,   true);
  setPos('reel-artist', Math.floor(artists.length / 2));
  setPos('reel-song',   Math.floor(songs.length / 2));
  setPos('reel-year',   Math.floor(years.length / 2));
}

function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

function animateReel(reelId, items, targetIdx, delay) {
  return new Promise(resolve => {
    setTimeout(() => {
      const reel = document.getElementById(reelId);
      const total = items.length;
      const centeredOffset = targetIdx * ITEM_H - (WIN_H / 2 - ITEM_H / 2) + PAD * ITEM_H;
      const totalDist = (4 + Math.floor(Math.random() * 3)) * total * ITEM_H + centeredOffset;
      const duration = 1600 + delay * 280 + Math.random() * 300;
      let start = null;
      function step(ts) {
        if (!start) start = ts;
        const p = Math.min((ts - start) / duration, 1);
        const pos = easeOutQuart(p) * totalDist;
        const cycled = pos % (total * ITEM_H);
        reel.style.transform = `translateY(${-(cycled + PAD * ITEM_H - (WIN_H / 2 - ITEM_H / 2))}px)`;
        const cIdx = Math.round(cycled / ITEM_H) % total;
        reel.querySelectorAll('.slot-item').forEach((el, i) => el.classList.toggle('active', i === cIdx + PAD));
        if (p < 1) { requestAnimationFrame(step); }
        else {
          reel.style.transform = `translateY(${-centeredOffset}px)`;
          reel.querySelectorAll('.slot-item').forEach((el, i) => el.classList.toggle('active', i === targetIdx + PAD));
          resolve();
        }
      }
      requestAnimationFrame(step);
    }, delay * 60);
  });
}

let isSpinning = false, spinHistory = [], spinCount = 0;
let currentTrack = null, verdictCast = false;

async function spinAll() {
  if (isSpinning) return;
  isSpinning = true;
  verdictCast = false;
  currentTrack = null;

  const btn = document.getElementById('spinBtn');
  const machine = document.getElementById('machine');
  btn.disabled = true;
  btn.textContent = '⟳ PROCESSING...';
  document.getElementById('statusText').textContent = 'SPINNING';
  machine.classList.add('spinning');
  document.getElementById('resultPanel').classList.remove('visible');
  document.getElementById('verdictRow').classList.remove('visible');
  document.getElementById('qrAnchor').style.display = 'none';
  document.getElementById('qr-container').innerHTML = '';
  document.getElementById('voteCounts').style.display = 'none';

  const pick = catalog[Math.floor(Math.random() * catalog.length)];
  currentTrack = pick;

  const artists = [...new Set(catalog.map(t => t.artist))];
  const songs   = catalog.map(t => t.song);
  const years   = [...new Set(catalog.map(t => t.year))].sort();

  const aIdx = artists.indexOf(pick.artist);
  const sIdx = songs.indexOf(pick.song);
  const yIdx = years.indexOf(pick.year);

  await Promise.all([
    animateReel('reel-artist', artists, aIdx, 0),
    animateReel('reel-song',   songs,   sIdx, 1),
    animateReel('reel-year',   years,   yIdx, 2)
  ]);

  machine.classList.remove('spinning');
  document.getElementById('statusText').textContent = 'HALTED';

  // Update track panel fields
  document.getElementById('songTitle').textContent = pick.song;
  document.getElementById('songMeta').innerHTML = `ARTIST: <span class="hi">${pick.artist}</span> // YEAR: <span class="hi">${pick.year}</span>`;

  // Dynamic QR Destination generation and Anchor handling
  const targetUrl = `https://www.youtube.com/watch?v=${pick.vid}`;
  const anchor = document.getElementById('qrAnchor');
  anchor.href = targetUrl;
  anchor.style.display = 'block';

  new QRCode(document.getElementById('qr-container'), {
    text: targetUrl,
    width: 64,
    height: 64,
    colorDark: "#000000",
    colorLight: "#ffffff"
  });

  document.getElementById('resultPanel').classList.add('visible');
  document.getElementById('verdictRow').classList.add('visible');

  spinCount++;
  document.getElementById('spinCounter').textContent = String(spinCount).padStart(3, '0');

  btn.disabled = false;
  btn.textContent = '▶ EXECUTE SPIN';
  isSpinning = false;
}

function castVerdict(type) {
  if (!currentTrack || verdictCast) return;
  verdictCast = true;

  const votes = getVotes(currentTrack);
  votes[type]++;

  document.getElementById('voteAcceptDisplay').textContent = `✔ ${votes.accept}`;
  document.getElementById('voteDenyDisplay').textContent = `✖ ${votes.deny}`;
  document.getElementById('voteCounts').style.display = 'flex';

  // Push into local logging arrays
  spinHistory.unshift({
    track: currentTrack,
    verdict: type === 'accept' ? 'ACCEPTED' : 'DENIED'
  });

  updateHistoryUI();
}

function updateHistoryUI() {
  const section = document.getElementById('historySection');
  const list = document.getElementById('historyList');
  document.getElementById('histCount').textContent = `${spinHistory.length} ENTRIES`;
  
  list.innerHTML = '';
  spinHistory.forEach((item, index) => {
    const el = document.createElement('div');
    el.className = 'history-item';
    el.innerHTML = `
      <div class="h-idx">#${String(spinHistory.length - index).padStart(2, '0')}</div>
      <div class="h-song">${item.track.song} — ${item.track.artist}</div>
      <div class="h-info">${item.track.year}</div>
      <div class="h-verdict ${item.verdict.toLowerCase()}">${item.verdict}</div>
    `;
    list.appendChild(el);
  });
  section.style.display = 'block';
}

window.onload = initReels;
